{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "src/global.d.ts",
    "tests/renderer/**/*",
    "tests/setup.ts"
  ],
  "exclude": ["src/main/**/*"],
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "composite": true,
    "noEmit": true,
    "outDir": "./.tsc-root/web",
    "tsBuildInfoFile": "./.tsc-root/tsconfig.web.tsbuildinfo",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/*"],
      "@shared/*": ["src/shared/*"]
    },
    "noFallthroughCasesInSwitch": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  }
}
